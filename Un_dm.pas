implementation

uses Un_dao, Math, Un_splash;

{$R *.dfm}

procedure TDm.ftpSiteWorkBegin(Sender: TObject; AWorkMode: TWorkMode;
  const AWorkCountMax: Integer);
begin
  if (fm_splash = nil) then
    exit;

   fm_splash.ggProgress.MaxValue:= bytesToTransfer;
end;

procedure TDm.ftpSiteWork(Sender: TObject; AWorkMode: TWorkMode;
  const AWorkCount: Integer);
begin
  if (fm_splash = nil) then
    exit;
  fm_splash.ggProgress.Progress := AWorkCount;
end;

end.


