  object Q_UltimasCompras: TFDQuery
    Connection = dao.CN
    SQL.Strings = (
      
        'select cast (E2.QTD_ENTRADA as double precision) AS ULT_QTD_ENTR' +
        'ADA,'
      '       cast (E2.CUSTO as double precision) AS ULTIMO_CUSTO,'
      '       E1.DTA_DOCUMENTO AS ULT_COMPRA,'
      '       E1.NR_DOCUMENTO,'
      
        '       cast(F.COD_FORNECEDOR || '#39'-'#39' || F.RAZAO_SOCIAL as varchar' +
        '(200)) AS FORNECEDOR'
      'from ENTRADA2 E2'
      
        '     inner JOIN ENTRADA1 E1 ON (E1.COD_FORNECEDOR = E2.COD_FORNE' +
        'CEDOR AND E1.NR_DOCUMENTO = E2.NR_DOCUMENTO AND (E1.DTA_DOCUMENT' +
        'O ='
      '     ('
      '       SELECT MAX(E3.DTA_DOCUMENTO)'
      '       FROM ENTRADA1 E3'
      
        '            LEFT OUTER JOIN ENTRADA2 E4 ON (E3.COD_FORNECEDOR = ' +
        'E4.COD_FORNECEDOR AND E3.NR_DOCUMENTO = E4.NR_DOCUMENTO)'
      '       WHERE E4.COD_PRODUTO = e2.COD_PRODUTO AND'
      '             E3.COD_FORNECEDOR = e1.cod_fornecedor'
      '     )))'
      
        '     inner JOIN FORNECEDOR F ON (F.COD_FORNECEDOR = E1.COD_FORNE' +
        'CEDOR)'
      'WHERE e2.COD_produto =:produto'
      'ORDER BY E1.DTA_DOCUMENTO DESC'
      'limit 5')
    Left = 41
    Top = 141
    ParamData = <
      item
        Name = 'PRODUTO'
        DataType = ftInteger
        ParamType = ptInput
      end>
