  object fR_RELATORIO: TfrxReport
    Version = '6.9.3'
    DotMatrixReport = False
    EngineOptions.PrintIfEmpty = False
    IniFile = '\Software\Fast Reports'
    PreviewOptions.Buttons = [pbPrint, pbLoad, pbSave, pbExport, pbZoom, pbFind, pbOutline, pbPageSetup, pbTools, pbEdit, pbNavigator, pbExportQuick]
    PreviewOptions.Zoom = 1.000000000000000000
    PrintOptions.Printer = 'Default'
    PrintOptions.PrintOnSheet = 0
    ReportOptions.CreateDate = 40434.466838645800000000
    ReportOptions.LastChange = 42534.418069097220000000
    ScriptLanguage = 'PascalScript'
    ScriptText.Strings = (
      'var linhas, linha_final : integer;'
      '  '
      'procedure GroupHeader1OnBeforePrint(Sender: TfrxComponent);'
      'begin'
      '  linhas := MasterData1.DataSet.RecNo - linha_final;'
      
        '    if ((engine.freespace) < (GroupHeader1.height + (MasterData1' +
        '.height * (linhas+1)) + (GroupFooter1.height))) then'
      '  begin'
      '//    showmessage(floattostr(linhas));'
      '            '
      '    engine.NewColumn;'
      '  end;      '
      'end;'
      ''
      'procedure GroupFooter1OnBeforePrint(Sender: TfrxComponent);'
      'begin'
      '                  '
      'end;'
      ''
      ''
      ''
      'procedure GroupHeader1OnAfterPrint(Sender: TfrxComponent);'
      'begin'
      '      linha_final := MasterData1.DataSet.RecNo;'
      'end;'
      ''
      'procedure PageFooter1OnBeforePrint(Sender: TfrxComponent);'
      'begin'
      
        '  mmLiquidacao.visible := <dst_mala_direta1."LIQUIDACAO"> = '#39'S'#39';' +
        '                                                                ' +
        '     '
      'end;'
      ''
      
        'function StringReplace(before:String;Old:string;New:string):stri' +
        'ng;'
      'var'
      '  temporal:string;'
      'begin'
      '  temporal := before;'
      '  DeleteStr(temporal,Pos(Old,Before),length(Old));'
      '  Insert(temporal,New,Pos(Old,Before));'
      '  result := temporal;'
      'end;  '
      '  '
      'function Explode(str, separador: string): TStringList;'
      'var'
      '  p: integer;'
      'begin'
      '  Result := TStringList.Create;'
      ''
      '  p := Pos(separador, str);'
      '  while (p > 0) do'
      '  begin'
      '    Result.Add(Copy(str, 1, p - 1));'
      '    Delete(str, 1, p + Length(separador) - 1);'
      '    p := Pos(separador, str);'
      '  end;'
      ''
      '  if (str <> '#39#39') then'
      '    Result.Add(str);'
      'end;  '
      '  '
      'procedure MasterData1OnBeforePrint(Sender: TfrxComponent);'
      'var'
      '  sub_cat, prod_it : TStringList;'
      '  x, y : integer;'
      
        '  prod_desc : string;                                           ' +
        '     '
      'begin'
      
        '    {[dst_catalogo."COD_PRODUTO"] - [dst_catalogo."NOM_PRODUTO"]' +
        '}'
      '  sub_cat := TStringList.create;'
      '  prod_it := TStringList.create;'
      ''
      
        '  sub_cat   := explode(trim(<dst_mala_direta1."SUBCATEGORIA">),'#39 +
        ' '#39');'
      
        '  prod_it   := explode(trim(<dst_mala_direta1."NOM_PRODUTO">),'#39' ' +
        #39');'
      ''
      '  prod_desc := <dst_mala_direta1."NOM_PRODUTO">;'
      '             '
      '  for x:=0 to prod_it.count-1 do'
      '  begin                '
      '      '
      '    for y:=0 to sub_cat.count-1 do'
      '    begin'
      '      if (sub_cat[y] = prod_it[x]) then'
      '      begin                  '
      '         prod_desc := stringreplace(prod_desc, sub_cat[y], '#39#39');'
      '      end;'
      '    end;               '
      '  end;'
      '  '
      '  if trim(prod_desc) = '#39#39' then'
      '    prod_desc := <dst_mala_direta1."NOM_PRODUTO">;      '
      '  '
      
        '  mmItem.text := trim(prod_desc)+'#39' - '#39'+<dst_mala_direta1."PACOTE' +
        '">;'
      '    '
      '  sub_cat.free;'
      '  prod_it.free;  '
      'end;'
      ''
      'begin'
      ''
      'end.')
