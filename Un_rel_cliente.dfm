      Origin = 'contato'
      Size = 30
    end
    object qu_clientenom_cidade: TStringField
      AutoGenerateValue = arDefault
      FieldName = 'nom_cidade'
      Origin = 'nom_cidade'
      Size = 40
    end
    object qu_clienteuf: TStringField
