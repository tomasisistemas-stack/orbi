  object qu_cliente: TFDQuery
    Connection = dao.CN
    SQL.Strings = (
      
        'select cod_cliente, nom_cliente, c.contato, cd.nom_cidade, cd.uf' +
        ', telefone from cliente c '
      'left join cidades cd on cd.cod_cidade=c.cod_cidade'
      'order by cd.nom_cidade, nom_cliente')
    Left = 744
    Top = 32
    object qu_clientecod_cliente: TIntegerField
      FieldName = 'cod_cliente'
      Origin = 'cod_cliente'
      ProviderFlags = [pfInUpdate, pfInWhere, pfInKey]
    end
