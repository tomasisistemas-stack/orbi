  object q_mov_ent: TFDQuery
    Connection = dao.CN
    SQL.Strings = (
      
        'select P.cod_produto, p.NOM_PRODUTO, coalesce(p.CONT_ESTOQUE_AGO' +
        '_2010,0) as cont_estoque_ago_2010, P.QTD_ESTOQUE, P.QTD_RESERVAD' +
        'O, c.COD_FORNECEDOR AS CODIGO_CLIENTE_FORNECEDOR, c.RAZAO_SOCIAL' +
        ' AS NOME_CLIENTE_FORNECEDOR, v1.NR_DOCUMENTO as NUMDOC, v1.DTA_D' +
        'OCUMENTO as data_MOV, v1.NOTA_FISCAL, v2.QTD_ENTRADA AS QTD, v2.' +
        'QTD_ENTRADA as cont, '#39'ENTRADA (+)'#39' AS TIPO, v2.CUSTO, v2.CUSTO_F' +
        'INAL'
      'from entrada2 v2'
      
        'inner join entrada1 v1 on (v1.COD_FORNECEDOR = v2.COD_FORNECEDOR' +
        ' and v1.NR_DOCUMENTO = v2.NR_DOCUMENTO)'
      
        'inner join FORNECEDOR c on (v1.COD_FORNECEDOR = C.COD_FORNECEDOR' +
        ')'
      'inner join produto p on (p.cod_produto = v2.COD_PRODUTO)'
      'WHERE 1 = 1'
      '  and v2.cod_produto = :produto'
      '  and v1.DTA_DOCUMENTO between :dtini and :dtfim'
      'order by v1.DTA_DOCUMENTO ')
    Left = 208
    Top = 56
    ParamData = <
      item
        Name = 'PRODUTO'
        DataType = ftInteger
        ParamType = ptInput
      end
      item
        Name = 'DTINI'
        DataType = ftDate
        ParamType = ptInput
      end
      item
        Name = 'DTFIM'
        DataType = ftDate
        ParamType = ptInput
      end>
