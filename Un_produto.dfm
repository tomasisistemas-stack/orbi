  object q_mov_fat: TFDQuery
    Connection = dao.CN
    SQL.Strings = (
      
        'select P.cod_produto, p.NOM_PRODUTO, coalesce(p.CONT_ESTOQUE_AGO' +
        '_2010,0) as cont_estoque_ago_2010, P.QTD_ESTOQUE, P.QTD_RESERVAD' +
        'O, c.COD_CLIENTE AS CODIGO_CLIENTE_FORNECEDOR, c.NOM_CLIENTE AS ' +
        'NOME_CLIENTE_FORNECEDOR, v1.NUMDOC, coalesce(v1.DTA_EMISSAO, v1.' +
        'DTADOC) as data_mov, v1.NFE as NOTA_FISCAL, v2.QTD, v2.QTD*(-1) ' +
        'as cont, '#39'SA'#205'DA (-)'#39' AS TIPO, v2.PRECO, v2.SUB_TOTAL'
      'from vendas2 v2'
      
        'inner join vendas1 v1 on (v1.NUMDOC = v2.NUMDOC and v1.FATURADO ' +
        '=1 and v1.NFE_DEV is null)'
      'inner join cliente c on (C.COD_CLIENTE = v1.COD_CLIENTE)'
      'inner join produto p on (p.cod_produto = v2.COD_PRODUTO)'
      'where 1 = 1'
      'and v2.cod_produto = :produto'
      'and v1.DTA_EMISSAO between :dtini and :dtfim'
      'order by v1.DTA_EMISSAO')
