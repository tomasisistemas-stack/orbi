  object q_mov_res: TFDQuery
    Connection = dao.CN
    SQL.Strings = (
      
        'select P.cod_produto, p.NOM_PRODUTO, coalesce(p.CONT_ESTOQUE_AGO' +
        '_2010,0) as cont_estoque_ago_2010, P.QTD_ESTOQUE, P.QTD_RESERVAD' +
        'O, c.COD_CLIENTE AS CODIGO_CLIENTE_FORNECEDOR, c.NOM_CLIENTE AS ' +
        'NOME_CLIENTE_FORNECEDOR, v1.NUMDOC, v1.dtadoc as data_mov, v1.NF' +
        'E as NOTA_FISCAL, v2.QTD, v2.QTD*(-1) as cont, '#39'RESERVADO (-)'#39' A' +
        'S TIPO, v2.PRECO, v2.SUB_TOTAL'
