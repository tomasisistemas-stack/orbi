  object q_mov_acerto: TFDQuery
    Connection = dao.CN
    SQL.Strings = (
      
        'select P.cod_produto, p.NOM_PRODUTO, coalesce(p.CONT_ESTOQUE_AGO' +
        '_2010,0) as cont_estoque_ago_2010, P.QTD_ESTOQUE, P.QTD_RESERVAD' +
        'O, 0 AS CODIGO_CLIENTE_FORNECEDOR, '#39'ACERTO DE ESTOQUE'#39' AS NOME_C' +
        'LIENTE_FORNECEDOR, A.ID as NUMDOC, a.data_acerto AS DATA_MOV, A.' +
        'ID AS NOTA_FISCAL, A.QTD_ACERTO AS QTD, A.QTD_ACERTO as cont, '#39'A' +
        'CERTO'#39' AS TIPO'
      'from ACERTO_ESTOQUE A'
      'inner join produto p on (p.cod_produto = A.COD_PRODUTO )'
      
        'WHERE  a.DATA_ACERTO = COALESCE((select max(aE.data_acerto) from' +
        ' ACERTO_ESTOQUE aE where a.cod_produto = ae.cod_produto), '#39'01/01' +
        '/2019'#39')'
      'and a.cod_produto = :produto'
      'and a.DATA_ACERTO between :dtini and :dtfim'
      'order by a.DATA_ACERTO')
    Left = 56
    Top = 96
    ParamData = <
      item
        Name = 'PRODUTO'
        DataType = ftInteger
        ParamType = ptInput
      end
      item
        Name = 'DTINI'
        DataType = ftDate
        ParamType = ptInput
      end
      item
        Name = 'DTFIM'
        DataType = ftDate
        ParamType = ptInput
      end>
