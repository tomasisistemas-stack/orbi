        'ight ) ) then'
      '        n := n + memContInfAdicionais.CalcHeight;'
      '    end;'
      '  end;'
      ''
      '  while ((Engine.FreeSpace - ChildCorpo.Height ) >= n ) do'
      '    Engine.ShowBand(ChildCorpo);'
