  object qr_nfe_email: TFDQuery
    Connection = dao.CN
    SQL.Strings = (
      'SELECT'
      '  a.NUMDOC,'
      
        '  case when a.COD_CLIENTE is null then f.EMAIL else c.EMAIL_END_' +
        'NFE end as NFE_EMAIL,'
      
        '  case when a.COD_CLIENTE is null then f.EMAIL else c.EMAIL end ' +
        'as EMAIL,'
      '  a.CHAVE_NFE,'
      '  a.EMAIL_NFE,'
      '  a.NFE,'
      '  c.EMAIL_ADICIONAL1,'
      '  c.EMAIL_ADICIONAL2,'
      '  c.EMAIL_ADICIONAL3,'
      '  a.XML,'
      '  a.XML_DEV,'
      '  e.cod_empresa,'
      '  E.nom_empresa'
      'FROM VENDAS1 a'
      'LEFT OUTER JOIN CLIENTE c on (c.COD_CLIENTE = a.COD_CLIENTE)'
      
        'LEFT OUTER JOIN FORNECEDOR F on (f.COD_FORNECEDOR = a.COD_FORNEC' +
        'EDOR)'
      'INNER JOIN EMPRESA E ON E.cod_empresa = A.empresa_faturar'
      'where a.FATURADO in ('#39'1'#39', '#39'3'#39')'
      '  and a.nfe is not null'
      
        '  and case when a.COD_CLIENTE is null then f.NFE_EMAIL else c.NF' +
        'E_EMAIL end = '#39'S'#39
      
        '  and case when a.COD_CLIENTE is null then f.EMAIL else c.EMAIL ' +
        'end is not null'
      '  and a.numdoc = :numdoc')
    Left = 664
    Top = 376
    ParamData = <
      item
        Name = 'NUMDOC'
        DataType = ftInteger
        FDDataType = dtUInt64
        ParamType = ptInput
      end>
    object qr_nfe_emailnumdoc: TIntegerField
      FieldName = 'numdoc'
      Origin = 'numdoc'
      ProviderFlags = [pfInUpdate, pfInWhere, pfInKey]
    end
