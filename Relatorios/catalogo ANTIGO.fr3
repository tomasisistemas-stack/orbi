<TfrxReport Version="4.3" DotMatrixReport="False" EngineOptions.PrintIfEmpty="False" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="4095" PreviewOptions.Zoom="1" PrintOptions.Printer="Default" PrintOptions.PrintOnSheet="0" ReportOptions.CreateDate="40434,4668386458" ReportOptions.Description.Text="" ReportOptions.LastChange="41723,4299666319" ScriptLanguage="PascalScript" ScriptText.Text="var linhas, linha_final : integer;&#13;&#10;  &#13;&#10;procedure GroupHeader1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;var&#13;&#10;  espaco, frame_espaco : real;                                                                                     &#13;&#10;begin&#13;&#10;  linhas       := &#60;dst_catalogo.&#34;ORDEM&#34;&#62;;&#13;&#10;  espaco       := engine.freespace;&#13;&#10;  frame_espaco := GroupHeader1.height + (MasterData1.height * (linhas)) + GroupFooter1.height;                                                      &#13;&#10;{    showmessage(&#60;dst_catalogo.&#34;SubCategoria&#34;&#62;);                                      &#13;&#10;    showmessage('frame: '+floattostr(GroupHeader1.height + (MasterData1.height * (linhas)) + GroupFooter1.height));&#13;&#10;    showmessage('espaço: '+floattostr(engine.freespace));&#13;&#10;}           &#13;&#10;      &#13;&#10;  if espaco &#60; frame_espaco then&#13;&#10;  begin&#13;&#10;            &#13;&#10;&#13;&#10;{    if TRIM(&#60;dst_catalogo.&#34;SubCategoria&#34;&#62;) = 'ARRUELA DE PRESSAO INOX' then&#13;&#10;    begin&#13;&#10;      showmessage(floattostr(linha_final));  &#13;&#10;      showmessage(floattostr(engine.freespace));&#13;&#10;      showmessage(floattostr((GroupHeader1.height + (MasterData1.height * (linhas+4)) + (GroupFooter1.height))));                &#13;&#10;    end;}              &#13;&#10;     &#13;&#10;&#13;&#10;    engine.NewColumn;&#13;&#10;  end;    &#13;&#10;end;        &#13;&#10;&#13;&#10;&#13;&#10;procedure GroupHeader1OnAfterPrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;//  linha_final := MasterData1.DataSet.RecNo;&#13;&#10;end;&#13;&#10;&#13;&#10;&#13;&#10;procedure GroupHeader1OnAfterCalcHeight(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  // GroupHeader1.height := Picture3.height * (1.18);&#13;&#10;end;&#13;&#10;&#13;&#10;procedure MasterData1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  if MasterData1.DataSet.RecNo mod 2 = 0 then&#13;&#10;    mmItem.color := clMoneyGreen          &#13;&#10;  else              &#13;&#10;    mmItem.color := clWhite;          &#13;&#10;end;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end." PropData="">
