<TfrxReport Tag="1" Version="6.9.3" DotMatrixReport="False" EngineOptions.PrintIfEmpty="False" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="4095" PreviewOptions.Zoom="1" PrintOptions.Printer="Default" PrintOptions.PrintOnSheet="0" ReportOptions.CreateDate="40180,4233186806" ReportOptions.Description.Text="" ReportOptions.LastChange="44326,9425916435" ScriptLanguage="PascalScript" ScriptText.Text="&#13;&#10;var&#13;&#10;  SaldoTotal, TotalCheques, TotalChequesTerceiros, TotalDinheiro, TotalPermuta : double;&#13;&#10;&#13;&#10;procedure DetailData1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  if &#60;dst_extrato.&#34;TIPO&#34;&#62; = '0' then&#13;&#10;    TotalDinheiro := TotalDinheiro + &#60;dst_extrato.&#34;VALOR&#34;&#62;;&#13;&#10;&#13;&#10;  if &#60;dst_extrato.&#34;TIPO&#34;&#62; = '1' then&#13;&#10;    TotalCheques  := TotalCheques + &#60;dst_extrato.&#34;VALOR&#34;&#62;;&#13;&#10;&#13;&#10;  if &#60;dst_extrato.&#34;TIPO&#34;&#62; = '2' then&#13;&#10;    TotalChequesTerceiros  := TotalChequesTerceiros + &#60;dst_extrato.&#34;VALOR&#34;&#62;;&#13;&#10;&#13;&#10;  if &#60;dst_extrato.&#34;TIPO&#34;&#62; = '3' then&#13;&#10;    TotalPermuta  := TotalPermuta + &#60;dst_extrato.&#34;VALOR&#34;&#62;;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure DetailData1OnAfterPrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure DetailData1OnAfterCalcHeight(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  if (length(memo5.text) &#62; 80) then&#13;&#10;  begin&#13;&#10;    memo5.Height := memo5.Height * ((length(memo5.text) div 80)+1);&#13;&#10;    mmDC.Height := mmDC.Height * ((length(memo5.text) div 80)+1);&#13;&#10;    mmValor.Height := mmValor.Height * ((length(memo5.text) div 80)+1);&#13;&#10;    mmExtrato.Height := mmExtrato.Height * ((length(memo5.text) div 80)+1);&#13;&#10;    detaildata1.Height := detaildata1.Height * ((length(memo5.text) div 80)+1);&#13;&#10; end;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure GroupFooter1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  SaldoTotal := SaldoTotal + &#60;dst_extrato.&#34;SALDO&#34;&#62;;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Page1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  SaldoTotal    := 0;&#13;&#10;  TotalCheques  := 0;&#13;&#10;  TotalChequesTerceiros  := 0;&#13;&#10;  TotalDinheiro := 0;&#13;&#10;  TotalPermuta := 0;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Memo7OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  Memo7.text             := 'Saldo Total: '+ formatfloat('R$ #,###,##0.00;(R$ #,###,##0.00)', SaldoTotal);&#13;&#10;  MmDinheiro.text        := 'Total em Dinheiro: '+ formatfloat('R$ #,###,##0.00;(R$ #,###,##0.00)', TotalDinheiro);&#13;&#10;  MmCheque.text          := 'Total em Cheques Próprios: '+ formatfloat('R$ #,###,##0.00;(R$ #,###,##0.00)', TotalCheques);&#13;&#10;  MmChequeTerceiros.text := 'Total em Cheques de Terceiros: '+ formatfloat('R$ #,###,##0.00;(R$ #,###,##0.00)', TotalChequesTerceiros);&#13;&#10;  MmTotalPermuta.text    := 'Total em Permutas: '+ formatfloat('R$ #,###,##0.00;(R$ #,###,##0.00)', TotalPermuta);&#13;&#10;end;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end." OnReportPrint="frxReportOnReportPrint">
